This is Server Script For Create Payments

payments = frappe.form_dict.get("payments")

if not payments:
    frappe.throw("No payments found")

payments = json.loads(payments)

created_entries = []

company = frappe.db.get_single_value("Global Defaults", "default_company")
company_currency = frappe.db.get_value("Company", company, "default_currency")

for row in payments:

    # 🔴 VALIDATIONS
    if not row.get("customer"):
        frappe.throw("Customer missing")

    if not row.get("sales_invoice"):
        frappe.throw("Sales Invoice missing")

    if not row.get("account_received_into"):
        frappe.throw("Receiving account missing")

    if not row.get("mode_of_payment"):
        frappe.throw("Mode of Payment missing")

    amount = float(row.get("paid_amount") or 0)

    if amount <= 0:
        continue

    # 🔥 GET CORRECT RECEIVABLE ACCOUNT
    receivable_account = frappe.db.get_value("Company", company, "default_receivable_account")

    # 🔥 CHECK OUTSTANDING
    outstanding = frappe.db.get_value("Sales Invoice",row.get("sales_invoice"),"outstanding_amount")
    

    if amount > float(outstanding):
        frappe.throw(f"Overpayment not allowed for {row.get('sales_invoice')}")

    # 🔥 CREATE PAYMENT ENTRY
    pe = frappe.get_doc({
        "doctype": "Payment Entry",
        "payment_type": "Receive",
        "party_type": "Customer",
        "party": row.get("customer"),
        "company": company,
        "posting_date": frappe.utils.today(),
        "mode_of_payment": row.get("mode_of_payment"),

        "paid_from": receivable_account,
        "paid_to": row.get("account_received_into"),

        "paid_amount": amount,
        "received_amount": amount,

        "paid_from_account_currency": company_currency,
        "paid_to_account_currency": company_currency,
        "source_exchange_rate": 1,
        "target_exchange_rate": 1
    })

    pe.append("references", {
        "reference_doctype": "Sales Invoice",
        "reference_name": row.get("sales_invoice"),
        "allocated_amount": amount
    })

    # Optional cheque fields
    if row.get("cheque"):
        pe.reference_no = row.get("cheque")

    if row.get("cheque_date"):
        pe.reference_date = row.get("cheque_date")

    pe.insert(ignore_permissions=True)
    pe.submit()

    created_entries.append(pe.name)

frappe.response["message"] = created_entries

