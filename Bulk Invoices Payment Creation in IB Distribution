This is Fetch Invoices Server script 

sales_person = frappe.form_dict.get("sales_person")
posting_date = frappe.form_dict.get("date")

if not sales_person:
    frappe.response["message"] = []
else:
    conditions = """
        WHERE si.sales_person = %s 
        AND si.docstatus = 1
        AND si.outstanding_amount > 0
        AND si.status IN ('Unpaid', 'Overdue', 'Partly Paid')
    """
    values = [sales_person]

    if posting_date:
        conditions += " AND si.posting_date = %s"
        values.append(posting_date)

    invoices = frappe.db.sql(f"""
        SELECT 
            si.name AS invoice,
            si.customer,
            si.posting_date,
            si.grand_total,
            si.outstanding_amount
        FROM `tabSales Invoice` si
        {conditions}
        ORDER BY si.posting_date DESC
    """, tuple(values), as_dict=True)

    frappe.response["message"] = invoices

