frappe.ui.form.on('Daily Payment', {
    refresh(frm) {

        frm.add_custom_button('Create Payments', () => {

            let payments = [];

            (frm.doc.payments || []).forEach(row => {

                if (row.paid_amount && row.paid_amount > 0) {

                    if (!row.customer || !row.sales_invoice) {
                        frappe.msgprint("Missing customer or invoice in row");
                        return;
                    }

                    payments.push({
                        sales_invoice: row.sales_invoice,
                        customer: row.customer,
                        paid_amount: row.paid_amount,
                        account_received_into: row.account_received_into || frm.doc.account_received_into,
                        mode_of_payment: row.mode_of_payment || frm.doc.mode_of_payment,
                        cheque: row.chequereference_no || null,
                        cheque_date: row.chequereference_date || null
                    });
                }

            });

            if (!payments.length) {
                frappe.msgprint("No valid payment rows");
                return;
            }

            console.log("Payments Payload:", payments); // DEBUG

            frappe.call({
                method: 'create_payments',
                args: {
                    payments: JSON.stringify(payments)
                },
                callback: function(r) {

                    if (r.message) {
                        frappe.msgprint({
                            title: "Success",
                            message: "Created:<br>" + r.message.join("<br>"),
                            indicator: "green"
                        });
                    }

                }
            });

        });

    }
});



frappe.ui.form.on('Daily Payments CT', {
	paid_amount:function(frm,cdt,cdn){
	    Balance(frm, cdt, cdn);
	}
})

function Balance(frm, cdt, cdn) {
    const row = locals[cdt][cdn];
    if (row.paid_amount && row.grand_total) {
        const value = row.grand_total - row.paid_amount;
        frappe.model.set_value(cdt, cdn, 'balance', parseFloat(value.toFixed(3)));
        frm.refresh_field('payments');
    }
}



frappe.ui.form.on('Daily Payment', {
	before_save: function(frm) {
		TotalAmount(frm);
	}
});

function TotalAmount(frm) {
	const ct = frm.doc.payments || [];
	let total_receivable_ = 0;
	let total_paid_ = 0;

	ct.forEach(row => {
		if (row.balance) {
			total_receivable_ += parseFloat(row.balance);
		}
		if (row.paid_amount) {
			total_paid_ += parseFloat(row.paid_amount);
		}
	});

	// Set correct totals
	console.log(total_receivable_,total_paid_)
	frm.set_value('total_receivable_', parseFloat(total_receivable_.toFixed(3)));
	frm.set_value('total_paid_', parseFloat(total_paid_.toFixed(3)));
}


