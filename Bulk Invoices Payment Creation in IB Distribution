/// Client Script For Fetch Invoices and Create Payment Buttons trggering the API endpoints

frappe.ui.form.on('Daily Payment', {
    refresh(frm) {
        frm.add_custom_button('Fetch Invoices', () => {
            if (!frm.doc.sales_person) {
                frappe.msgprint("Please select Sales Person");
                return;
            }

            frappe.call({
                method: 'fetch_invoices',
                args: {
                    sales_person: frm.doc.sales_person,
                    from_date: frm.doc.date,
                },
                callback: function(r) {

                    // Clear existing rows
                    frm.clear_table('multi_invoices');
                    // console.log(r.message)
                    (r.message || []).forEach(inv => {
                        let row = frm.add_child('payments');
                        
                        row.sales_invoice = inv.invoice;
                        row.customer = inv.customer;
                        row.date = inv.posting_date;
                        row.grand_total = inv.grand_total;
                    });

                    frm.refresh_field('payments');
                }
            });

        });

    }
});

